# =============================================================================
# Clip Services — copy to .env.local for local dev, or set each key in Vercel:
# Project → Settings → Environment Variables (Production + Preview).
# =============================================================================
# Quick check (after filling .env.local):  npm run verify-env
# New SESSION_SECRET:                          npm run gen:secret
# VAPID keys:                                 npx web-push generate-vapid-keys
# =============================================================================

# --- Required for production (Vercel) ---
# Redis: Vercel KV / Upstash / Redis Cloud — same connection string style as ioredis
KV_REDIS_URL=

# Random 32+ hex chars. Same value must be set on Vercel for OTP + signed cookies.
# Generate: npm run gen:secret
SESSION_SECRET=

# Long random string — protects /admin and admin push registration
ADMIN_TOKEN=

# Public site URL (no trailing slash). Stripe success/cancel + email links.
SITE_URL=https://clips-service.vercel.app

# Optional namespace if you share one Redis with other apps
KV_PREFIX=cs

# --- Email (Brevo) — required for provider OTP + transactional mail ---
# Brevo → SMTP & API: copy Login exactly (often something@smtp-brevo.com, not your Gmail)
BREVO_SMTP_USER=
BREVO_SMTP_KEY=
# Optional: default 587 + STARTTLS; use 465 + implicit SSL if 587 fails on your host
# BREVO_SMTP_PORT=587
# BREVO_SMTP_HOST=smtp-relay.brevo.com
# Must be a verified sender in Brevo
EMAIL_FROM=Clip Services <clipservices26@gmail.com>
# Inbound alerts for bookings, applications, etc.
ADMIN_EMAIL=clipservices26@gmail.com

# --- Stripe (optional — omit to disable card checkout) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Only if you add Stripe.js on the frontend later
STRIPE_PUBLISHABLE_KEY=

# --- Web Push / PWA (optional) ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=clipservices26@gmail.com

# --- One-time: push .env.local to Vercel (do not commit real .env.local) ---
# Create token: https://vercel.com/account/tokens
# npx vercel link
# $env:VERCEL_TOKEN='...'   # PowerShell
# npm run vercel:env:push
# npm run vercel:smoke
