# Vercel / local — never commit real secrets
KV_REDIS_URL=
KV_PREFIX=cs
ADMIN_TOKEN=
# Provider dashboard: one-time email OTP + 30-day signed cookie (use a long random string, 16+ chars)
SESSION_SECRET=
SITE_URL=https://your-domain.vercel.app

# Stripe (optional — leave blank to disable card payments)
# Publishable key only needed if you add Stripe.js / Elements on the frontend (Checkout uses server-side only).
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
# Signing secret from Developers → Webhooks → your endpoint, or shown once when creating via API
STRIPE_WEBHOOK_SECRET=

# Brevo SMTP (transactional email — leave blank to disable)
BREVO_SMTP_USER=
BREVO_SMTP_KEY=
EMAIL_FROM=Your App <you@example.com>
ADMIN_EMAIL=you@example.com

# Web Push (PWA notifications) — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=you@example.com
